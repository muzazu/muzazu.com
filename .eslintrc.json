{
	"env": {
		"browser": true,
		"es2021": true
	},
	"extends": [
		"plugin:react/recommended",
		"airbnb",
		"prettier",
		"prettier/react"
	],
	"parserOptions": {
		"ecmaFeatures": {
			"jsx": true
		},
		"ecmaVersion": 12,
		"sourceType": "module"
	},
	"plugins": ["react"],
	"rules": {
		// suppress errors for missing 'import React' in files
		"react/react-in-jsx-scope": "off",
		"react/jsx-props-no-spreading": "off",
		"import/no-unresolved": "off"
	}
}
